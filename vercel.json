{
  "version": 2,
  "builds": [
    {
      "src": "backend/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/index.js"
    },
    {
      "src": "/uploads/(.*)",
      "dest": "backend/index.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "frontend/assets/$1"
    },
    {
      "src": "/favicon.svg",
      "dest": "frontend/favicon.svg"
    },
    {
      "src": "/manifest.webmanifest",
      "dest": "frontend/manifest.webmanifest"
    },
    {
      "src": "/sw.js",
      "dest": "frontend/sw.js"
    },
    {
      "src": "/registerSW.js",
      "dest": "frontend/registerSW.js"
    },
    {
      "src": "/workbox-(.*).js",
      "dest": "frontend/workbox-$1.js"
    },
    {
      "src": "/apple-touch-icon.png",
      "dest": "frontend/apple-touch-icon.png"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/index.html"
    }
  ]
}
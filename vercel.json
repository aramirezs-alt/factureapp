{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/index.js",
      "use": "@vercel/node"
    }

  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "backend/index.js"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "backend/index.js"
    },
    {
      "source": "/((?!api|uploads|assets|favicon|apple-touch-icon|manifest|registerSW|sw|workbox|.*\\.).*)",
      "destination": "/index.html"
    }
  ]
}